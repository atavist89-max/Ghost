<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.ghost.app">

    <!--
        CRITICAL: No INTERNET permission declared
        This app operates completely offline with local LLM inference
    -->

    <!-- Storage permission for reading model file from external storage -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- AccessibilityService for silent screenshots (replaces MediaProjection) -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" />

    <application
        android:name=".GhostApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Ghost"
        android:hardwareAccelerated="true"
        tools:targetApi="36">

        <!-- Launcher Activity - transparent, captures screen and launches ChatActivity -->
        <activity
            android:name=".GhostActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.Ghost.Transparent"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Intent filter for Side Key double-tap trigger -->
            <intent-filter>
                <action android:name="com.ghost.app.ACTION_TRIGGER" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Chat Activity - Full screen chat interface -->
        <activity
            android:name=".ChatActivity"
            android:exported="false"
            android:theme="@style/Theme.Ghost.Chat"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden" />

        <!-- AccessibilityService for silent screenshot capture (replaces MediaProjection) -->
        <service
            android:name=".GhostAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true"
            android:label="Ghost Screen Analysis">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/ghost_accessibility_config" />
        </service>

    </application>

</manifest>
